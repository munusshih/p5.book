---
import Base from "@/layouts/Base.astro";
import "@/styles/worksheet.css";

const { frontmatter } = Astro.props;
---

<Base title={frontmatter.title ?? "p5.book workshop"}>
  <div class="title-section">
    <h1>{frontmatter.title}</h1>
  </div>
  <div class="content">
    <slot />
  </div>
  <div class="section-jump" aria-label="Jump between sections">
    <button id="section-up" type="button" aria-label="Previous section">
      ↑
    </button>
    <button id="section-down" type="button" aria-label="Next section">↓</button>
  </div>
  <nav class="bottom-nav" id="bottom-nav">
    <!-- Auto-populated by JavaScript -->
  </nav>
</Base>

<script>
  // Auto-populate navigation from headings
  const nav = document.getElementById("bottom-nav");
  const content = document.querySelector(".content");
  const sectionUpButton = document.getElementById("section-up");
  const sectionDownButton = document.getElementById("section-down");

  if (nav && content) {
    const headings = Array.from(content.querySelectorAll("h2"));
    const navLinks = [];

    const slugify = (text) =>
      text
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, "")
        .replace(/\s+/g, "-");

    const getHeadingNavMeta = (heading, index) => {
      const fullText = (heading.textContent || "").trim();
      const kbdText = heading.querySelector("kbd")?.textContent?.trim();
      const fallbackTitle = fullText || `Section ${index + 1}`;

      if (kbdText) {
        const titleMatch = fullText.match(/[A-Z0-9]\s*—\s*(.+)/);
        return {
          badge: kbdText,
          title: titleMatch ? titleMatch[1].trim() : fallbackTitle,
          idBase: fullText,
        };
      }

      return {
        badge: String(index + 1),
        title: fallbackTitle,
        idBase: fallbackTitle,
      };
    };

    headings.forEach((heading, index) => {
      const meta = getHeadingNavMeta(heading, index);
      if (!heading.id) heading.id = `section-${slugify(meta.idBase) || index + 1}`;

      const link = document.createElement("a");
      link.href = `#${heading.id}`;
      link.dataset.sectionIndex = String(index);

      const badge = document.createElement("span");
      badge.className = "nav-letter";
      badge.textContent = meta.badge;

      const label = document.createElement("span");
      label.className = "nav-label";
      label.textContent = meta.title;

      link.append(badge, label);
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const nextIndex = Number.parseInt(link.dataset.sectionIndex || "0", 10);
        goToSection(nextIndex);
      });
      nav.appendChild(link);
      navLinks.push(link);
    });

    let activeSectionIndex = 0;

    const setActiveSection = (index) => {
      if (!headings.length) return;

      const boundedIndex = Math.max(0, Math.min(index, headings.length - 1));
      activeSectionIndex = boundedIndex;

      navLinks.forEach((link, linkIndex) => {
        const isActive = linkIndex === boundedIndex;
        link.classList.toggle("is-active", isActive);
        if (isActive) link.setAttribute("aria-current", "true");
        else link.removeAttribute("aria-current");
      });

      if (sectionUpButton) sectionUpButton.disabled = boundedIndex === 0;
      if (sectionDownButton)
        sectionDownButton.disabled = boundedIndex === headings.length - 1;

      navLinks[boundedIndex]?.scrollIntoView({
        behavior: "smooth",
        block: "nearest",
        inline: "center",
      });
    };

    const goToSection = (index) => {
      if (!headings.length) return;
      const boundedIndex = Math.max(0, Math.min(index, headings.length - 1));
      headings[boundedIndex].scrollIntoView({ behavior: "smooth", block: "start" });
      setActiveSection(boundedIndex);
    };

    sectionUpButton?.addEventListener("click", () => {
      goToSection(activeSectionIndex - 1);
    });

    sectionDownButton?.addEventListener("click", () => {
      goToSection(activeSectionIndex + 1);
    });

    const updateActiveSectionFromScroll = () => {
      if (!headings.length) return;

      const offset = Math.min(window.innerHeight * 0.33, 240);
      let currentIndex = 0;
      headings.forEach((heading, index) => {
        if (heading.getBoundingClientRect().top - offset <= 0) {
          currentIndex = index;
        }
      });
      setActiveSection(currentIndex);
    };

    let scrollTicking = false;
    const scheduleActiveUpdate = () => {
      if (scrollTicking) return;
      scrollTicking = true;
      window.requestAnimationFrame(() => {
        updateActiveSectionFromScroll();
        scrollTicking = false;
      });
    };

    window.addEventListener("scroll", scheduleActiveUpdate, { passive: true });
    window.addEventListener("resize", scheduleActiveUpdate);
    updateActiveSectionFromScroll();

    if (!headings.length) {
      if (sectionUpButton) sectionUpButton.disabled = true;
      if (sectionDownButton) sectionDownButton.disabled = true;
    } else {
      setActiveSection(0);
      scheduleActiveUpdate();
    }
  } else {
    if (sectionUpButton) sectionUpButton.disabled = true;
    if (sectionDownButton) sectionDownButton.disabled = true;
  }

  if (content) {
    const steps = content.querySelectorAll(".step");
    let stepCounter = 0;

    steps.forEach((step) => {
      const manualStep = step.getAttribute("data-step")?.trim();

      if (manualStep) {
        const explicitNumber = Number.parseInt(manualStep, 10);
        if (Number.isFinite(explicitNumber)) {
          stepCounter = explicitNumber;
          step.dataset.stepLabel = String(explicitNumber);
          return;
        }

        step.dataset.stepLabel = manualStep;
        return;
      }

      stepCounter += 1;
      step.dataset.stepLabel = String(stepCounter);
    });
  }

  const languageLabels = {
    js: "JavaScript",
    javascript: "JavaScript",
    ts: "TypeScript",
    typescript: "TypeScript",
    html: "HTML",
    css: "CSS",
    json: "JSON",
    sh: "Shell",
    bash: "Bash",
    text: "Text",
    plaintext: "Text",
  };

  const toLanguageLabel = (language) => {
    if (!language) return "Text";
    if (languageLabels[language]) return languageLabels[language];
    return language.charAt(0).toUpperCase() + language.slice(1);
  };

  const detectCodeLanguage = (preElement, codeElement) => {
    const preLanguage = preElement?.dataset?.language;
    if (preLanguage) return preLanguage.toLowerCase();

    if (!codeElement) return "text";
    const match = codeElement.className.match(/language-([a-z0-9-]+)/i);
    return match ? match[1].toLowerCase() : "text";
  };

  if (content) {
    const codeBlocks = content.querySelectorAll("pre");

    codeBlocks.forEach((pre) => {
      if (pre.parentElement?.classList.contains("code-block")) return;

      const codeElement = pre.querySelector("code");
      const language = detectCodeLanguage(pre, codeElement);

      const wrapper = document.createElement("div");
      wrapper.className = "code-block";

      const header = document.createElement("div");
      header.className = "code-block-header";

      const languageTag = document.createElement("span");
      languageTag.className = "code-block-language";
      languageTag.textContent = toLanguageLabel(language);

      const copyButton = document.createElement("button");
      copyButton.type = "button";
      copyButton.className = "code-block-copy";
      copyButton.textContent = "Copy";
      copyButton.setAttribute(
        "aria-label",
        `Copy ${languageTag.textContent} code`,
      );

      let resetTimer;
      const setCopyState = (label, stateClass) => {
        if (resetTimer) window.clearTimeout(resetTimer);
        copyButton.textContent = label;
        copyButton.classList.remove("is-copied", "is-copy-manual");
        if (stateClass) copyButton.classList.add(stateClass);
        resetTimer = window.setTimeout(() => {
          copyButton.textContent = "Copy";
          copyButton.classList.remove("is-copied", "is-copy-manual");
        }, 1500);
      };

      copyButton.addEventListener("click", async () => {
        const sourceText = codeElement?.textContent ?? pre.textContent ?? "";
        if (!sourceText.trim()) return;

        try {
          if (!navigator.clipboard?.writeText) {
            throw new Error("Clipboard API unavailable");
          }
          await navigator.clipboard.writeText(sourceText);
          setCopyState("Copied", "is-copied");
        } catch {
          const selection = window.getSelection();
          const range = document.createRange();
          range.selectNodeContents(pre);
          selection?.removeAllRanges();
          selection?.addRange(range);
          setCopyState("Press Cmd/Ctrl+C", "is-copy-manual");
        }
      });

      header.append(languageTag, copyButton);
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.append(header, pre);
    });
  }
</script>

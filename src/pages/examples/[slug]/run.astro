---
// Bare canvas page — inlines sketch.js so there's no document.write shim,
// no file serving logic, and no shared sketch.html. Pure Astro.
const allMeta = import.meta.glob("../../../examples/*/meta.json", {
  eager: true,
});
const allCode = import.meta.glob("../../../examples/*/sketch.js", {
  query: "?raw",
  import: "default",
  eager: true,
});

export function getStaticPaths() {
  const metas = import.meta.glob("../../../examples/*/meta.json", {
    eager: true,
  });
  const codes = import.meta.glob("../../../examples/*/sketch.js", {
    query: "?raw",
    import: "default",
    eager: true,
  });

  return Object.entries(metas)
    .map(([metaPath, meta]) => {
      const slug = metaPath.match(/\/([^/]+)\/meta\.json$/)?.[1];
      if (!slug) return null;
      const codePath = metaPath.replace("meta.json", "sketch.js");
      return {
        params: { slug },
        props: {
          title: (meta as any).title as string,
          code: codes[codePath] as string,
        },
      };
    })
    .filter(Boolean)
    .sort((a, b) => a!.params.slug.localeCompare(b!.params.slug));
}

const { slug } = Astro.params;
const { title, code } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · p5.book</title>
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
      }
      canvas {
        display: block;
      }
    </style>
    <script is:inline src="https://cdn.jsdelivr.net/npm/p5@2/lib/p5.min.js"
    ></script>
    <script is:inline src="https://unpkg.com/jspdf@latest/dist/jspdf.umd.min.js"
    ></script>
    <script is:inline src="/p5.book.js"></script>
  </head>
  <body>
    <!-- sketch.js is inlined at build time — no runtime fetch, no document.write -->
    <script is:inline set:html={code} />
  </body>
</html>

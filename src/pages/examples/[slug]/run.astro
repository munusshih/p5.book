---
import { getCollection } from "astro:content";

// Bare canvas page — sketch code is entry.body, inlined at build time.
// No import.meta.glob, no document.write, no shared sketch.html.

export async function getStaticPaths() {
  const entries = await getCollection("examples");
  return entries
    .map((entry) => ({
      params: { slug: entry.id },
      props: {
        title: entry.data.title,
        code: entry.body!,
      },
    }))
    .sort((a, b) => a.params.slug.localeCompare(b.params.slug));
}

const { slug } = Astro.params;
const { title, code } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · p5.book</title>
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
      }
      canvas {
        display: block;
      }
    </style>
    <script is:inline src="https://cdn.jsdelivr.net/npm/p5@2/lib/p5.min.js"
    ></script>
    <script is:inline src="https://unpkg.com/jspdf@latest/dist/jspdf.umd.min.js"
    ></script>
    <script is:inline src="/p5.book.js"></script>
  </head>
  <body>
    <!-- sketch.js is inlined at build time — no runtime fetch, no document.write -->
    <script is:inline set:html={code} />
  </body>
</html>

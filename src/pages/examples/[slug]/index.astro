---
import { getCollection } from "astro:content";

// Split-pane example viewer — code panel left, live sketch iframe right.
// Source of truth: src/examples/<slug>.js — title/description from comment lines,
// code from entry.body. No import.meta.glob, no meta.json.

export async function getStaticPaths() {
  const entries = await getCollection("examples");
  return entries
    .map((entry) => ({
      params: { slug: entry.id },
      props: {
        title: entry.data.title,
        description: entry.data.description,
        code: entry.body!,
      },
    }))
    .sort((a, b) => a.params.slug.localeCompare(b.params.slug));
}

const { slug } = Astro.params;
const { title, description, code } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · p5.book</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css"
    />
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"
    ></script>
    <style>
      @font-face {
        font-family: "Apfel Grotezk";
        src:
          url("/fonts/ApfelGrotezk-Regular.woff2") format("woff2"),
          url("/fonts/ApfelGrotezk-Regular.woff") format("woff");
        font-weight: 300;
        font-style: normal;
      }

      @font-face {
        font-family: "Apfel Grotezk Brukt";
        src:
          url("/fonts/ApfelGrotezk-Brukt.woff2") format("woff2"),
          url("/fonts/ApfelGrotezk-Brukt.woff") format("woff");
        font-weight: 700;
        font-style: normal;
      }

      @font-face {
        font-family: "Apfel Grotezk";
        src:
          url("/fonts/ApfelGrotezk-Mittel.woff2") format("woff2"),
          url("/fonts/ApfelGrotezk-Mittel.woff") format("woff");
        font-weight: 500;
        font-style: normal;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        height: 100dvh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        font-size: 20px;
        font-family: "Apfel Grotezk", system-ui, sans-serif;
        font-weight: 300;
        background: #fff;
        color: #000;
      }

      #toolbar {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 0.65rem 1rem 0.7rem;
        flex-shrink: 0;
        border-bottom: 1px solid #000;
        background: orange;
      }

      #toolbar a {
        color: #000;
        text-decoration: underline;
        white-space: nowrap;
        font-size: 0.88rem;
        line-height: 1.4;
        margin-top: 0.1rem;
      }

      #meta {
        min-width: 0;
      }

      #title {
        display: block;
        font-family: "Apfel Grotezk", "Apfel Grotezk", sans-serif;
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.2;
      }

      #desc {
        display: block;
        font-size: 0.8rem;
        line-height: 1.4;
        color: #171717;
      }

      #main {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        overflow: hidden;
        background: #fffef9;
      }

      #code-panel {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border-right: 1px solid #000;
        background: #fffef9;
      }

      #code-scroll {
        flex: 1;
        overflow: auto;
      }

      #code-scroll pre {
        margin: 0;
      }

      #code-scroll code.hljs {
        font-size: 0.75rem;
        line-height: 1.65;
        padding: 16px 20px;
        min-height: 100%;
        font-family:
          "SFMono-Regular", Menlo, Monaco, Consolas, "Liberation Mono",
          "Courier New", monospace;
        background: #fffef9;
      }

      #preview-panel {
        overflow: hidden;
        background: #fff;
      }

      #preview-panel iframe {
        display: block;
        border: none;
        width: 100%;
        height: 100%;
      }

      @media (max-width: 700px) {
        #main {
          grid-template-columns: 1fr;
          grid-template-rows: minmax(16rem, 45%) minmax(18rem, 55%);
        }

        #toolbar {
          padding: 0.6rem 0.85rem 0.65rem;
        }

        #title {
          font-size: 0.95rem;
        }
      }
    </style>
  </head>
  <body>
    <div id="toolbar">
      <a href="/workshop/worksheet">← worksheet</a>
      <div id="meta">
        <span id="title">{title}</span>
        <span id="desc">{description}</span>
      </div>
    </div>
    <div id="main">
      <div id="code-panel">
        <div id="code-scroll">
          <pre><code id="code" class="language-javascript">{code}</code></pre>
        </div>
      </div>
      <div id="preview-panel">
        <iframe src={`/examples/${slug}/run/`} title="{title} sketch preview"
        ></iframe>
      </div>
    </div>

    <script is:inline>
      // highlight the pre-rendered code block
      document.addEventListener("DOMContentLoaded", () => {
        hljs.highlightElement(document.getElementById("code"));
      });
    </script>
  </body>
</html>

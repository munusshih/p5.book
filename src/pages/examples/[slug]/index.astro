---
import { getCollection } from "astro:content";

// Split-pane example viewer — code panel left, live sketch iframe right.
// All data comes from src/examples/[slug]/{meta.json,sketch.js} at build time.

export async function getStaticPaths() {
  const allCode = import.meta.glob("../../../examples/*/sketch.js", {
    query: "?raw",
    import: "default",
    eager: true,
  });

  const entries = await getCollection("examples");
  return entries
    .map((entry) => {
      const slug = entry.id.replace("/meta", "");
      const codePath = `../../../examples/${slug}/sketch.js`;
      return {
        params: { slug },
        props: {
          title: entry.data.title,
          description: entry.data.description,
          code: allCode[codePath] as string,
        },
      };
    })
    .sort((a, b) => a.params.slug.localeCompare(b.params.slug));
}

const { slug } = Astro.params;
const { title, description, code } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · p5.book</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css"
    />
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"
    ></script>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        height: 100dvh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        font-size: 20px;
        font-family: system-ui, sans-serif;
      }

      #toolbar {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 8px 12px;
        flex-shrink: 0;
        border-bottom: 1px solid;
      }

      #toolbar .spacer {
        flex: 1;
      }

      #title {
        font-weight: 500;
      }
      #desc {
        font-size: 14px;
        color: #666;
      }

      #main {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        overflow: hidden;
      }

      #code-panel {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border-right: 1px solid;
      }

      #code-scroll {
        flex: 1;
        overflow: auto;
      }

      #code-scroll pre {
        margin: 0;
      }

      #code-scroll code.hljs {
        font-size: 14px;
        line-height: 1.6;
        padding: 16px 20px;
        min-height: 100%;
        background: transparent;
      }

      #preview-panel {
        overflow: hidden;
      }

      #preview-panel iframe {
        display: block;
        border: none;
        width: 100%;
        height: 100%;
      }

      @media (max-width: 700px) {
        #main {
          grid-template-columns: 1fr;
          grid-template-rows: 50% 50%;
        }
      }
    </style>
  </head>
  <body>
    <div id="toolbar">
      <a href="/">← docs</a>
      <span id="title">{title}</span>
      <span id="desc">{description}</span>
      <span class="spacer"></span>
      <a href={`/examples/${slug}/run/`} target="_blank">open sketch ↗</a>
    </div>
    <div id="main">
      <div id="code-panel">
        <div id="code-scroll">
          <pre><code id="code" class="language-javascript">{code}</code></pre>
        </div>
      </div>
      <div id="preview-panel">
        <iframe src={`/examples/${slug}/run/`} title="{title} sketch preview"
        ></iframe>
      </div>
    </div>

    <script is:inline>
      // highlight the pre-rendered code block
      document.addEventListener("DOMContentLoaded", () => {
        hljs.highlightElement(document.getElementById("code"));
      });
    </script>
  </body>
</html>
